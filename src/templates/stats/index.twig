{% extends "_layouts/cp" %}

{% set title = "Stats Dashboard"|t('stamp-passport') %}
{% set selectedSubnavItem = 'stats' %}

{% set crumbs = [
    { label: settings.pluginName, url: url('stamp-passport') },
] %}

{% set weekdayLabels = weekdayCounts|keys %}
{% set weekdayValues = weekdayCounts|values %}
{% set quickChartConfig = {
    type: 'bar',
    data: {
        labels: weekdayLabels,
        datasets: [{
            label: 'Scans',
            data: weekdayValues,
            backgroundColor: '#1f7a8c'
        }]
    },
    options: {
        plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true } }
    }
}|json_encode %}

{% block contextMenu %}
    {% if craft.app.isMultiSite %}
        <div>
            <button type="button" class="btn menubtn" data-icon="world">{{ currentSite.name }}</button>
            <div class="menu">
                <ul class="padded">
                    {% for site in allSites %}
                        <li>
                            <a href="{{ url('stamp-passport/stats', { site: site.handle }) }}"
                               {% if site.id == currentSite.id %}class="sel"{% endif %}>
                                {{ site.name }}
                            </a>
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    {% endif %}
{% endblock %}

{% block content %}
    <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
        <div class="pane" style="padding: 1.25rem 1.5rem;">
            <p class="light" style="margin: 0 0 .25rem;">{{ 'Individual Visits'|t('stamp-passport') }}</p>
            <p style="font-size: 2em; font-weight: 600; margin: 0;">{{ totalIndividuals }}</p>
        </div>
        <div class="pane" style="padding: 1.25rem 1.5rem;">
            <p class="light" style="margin: 0 0 .25rem;">{{ 'Avg Locations Scanned'|t('stamp-passport') }}</p>
            <p style="font-size: 2em; font-weight: 600; margin: 0;">{{ avgLocations }}</p>
        </div>
    </div>

    <h2>{{ 'Top Scanned Locations'|t('stamp-passport') }}</h2>
    <table class="data fullwidth">
        <thead><tr><th>{{ 'Location'|t('stamp-passport') }}</th><th>{{ 'Scans'|t('stamp-passport') }}</th></tr></thead>
        <tbody>
            {% for title, count in locationCounts %}
                <tr><td>{{ title }}</td><td>{{ count }}</td></tr>
            {% else %}
                <tr><td colspan="2" class="light">{{ 'No location data yet.'|t('stamp-passport') }}</td></tr>
            {% endfor %}
        </tbody>
    </table>

    <h2 style="margin-top:2rem;">{{ 'Activity by Day of Week'|t('stamp-passport') }}</h2>
    <img alt="Activity by day of week" style="max-width:100%;height:auto;" src="https://quickchart.io/chart?c={{ quickChartConfig|url_encode }}">
{% endblock %}
