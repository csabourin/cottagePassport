{% extends "_layouts/cp" %}

{% set title = "QR Codes"|t('stamp-passport') %}
{% set selectedSubnavItem = 'qr-generator' %}

{% set crumbs = [
    { label: settings.pluginName, url: url('stamp-passport') },
] %}

{% block content %}
    <div class="field">
        <div class="heading">
            <label for="qr-base-url">
                {{ "Base URL"|t('stamp-passport') }}
            </label>
            <div class="instructions">
                <p>
                    {{ "The site URL where the passport frontend lives. QR codes will encode {baseUrl}?q={shortCode}."|t('stamp-passport') }}
                </p>
            </div>
        </div>
        <div class="input">
            <select id="qr-site-picker" class="text" style="margin-bottom:8px">
                {% for site in sites %}
                    <option value="{{ siteUrl(settings.routePrefix, {}, null, site.id) }}">
                        {{ site.name }}
                    </option>
                {% endfor %}
            </select>
        </div>
    </div>

    <div class="buttons" style="margin-bottom:24px">
        <button id="btn-print" class="btn" type="button">
            {{ "Print All QR Codes"|t('stamp-passport') }}
        </button>
    </div>

    {% if items|length %}
        <div id="qr-grid" class="passport-qr-grid">
            {% for item in items %}
                {% set content = item.contents[0] ?? null %}
                <div class="qr-card" data-shortcode="{{ item.shortCode }}">
                    <div class="qr-image">
                        <a href="#" target="_blank" rel="noopener">
                            <img src="" alt="QR {{ item.shortCode }}" width="200" height="200" loading="lazy"></a>
                        </div>
                        <div class="qr-label">
                            <strong>
                                {{ content ? content.title : 'Item #' ~ item.id }}
                            </strong>
                            <br>
                                <code>
                                    {{ item.shortCode }}
                                </code>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p>
                    {{ "No items yet."|t('stamp-passport') }}
                    <a href="{{ url('stamp-passport/items/new') }}">
                        {{ "Create one"|t('stamp-passport') }}
                    </a>
                    .
                </p>
            {% endif %}

        {% css %}
        .passport-qr-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 16px;
            }
            .qr-card {
            border: 1px solid var(--gray-200);
            border-radius: 6px;
            padding: 12px;
            text-align: center;
            background: #fff;
            }
            .qr-image img {
            max-width: 100%;
            height: auto;
            }
        .qr-label {
            margin-top: 8px;
            font-size: 13px;
            }
        {% endcss %}

{% js %}
(function() {
    var picker = document.getElementById('qr-site-picker');
    var cards = document.querySelectorAll('.qr-card');
    var qrCenterImageUrl = {{ (settings.qrCenterImageUrl ?? '')|json_encode|raw }};

    function updateQrCodes() {
        var baseUrl = picker.value.replace(/\/$/, '');
        cards.forEach(function(card) {
            var code = card.dataset.shortcode;
            var scanUrl = baseUrl + '?q=' + encodeURIComponent(code);
            var params = new URLSearchParams({
                size: '450',
                text: scanUrl
            });

            if (qrCenterImageUrl) {
                params.set('centerImageSizeRatio', '0.44');
                params.set('centerImageUrl', qrCenterImageUrl);
            }

            var qrApiUrl = 'https://quickchart.io/qr?' + params.toString();
            card.querySelector('img').src = qrApiUrl;
            card.querySelector('a')?.setAttribute('href', qrApiUrl);
        });
    }

    picker.addEventListener('change', updateQrCodes);
    updateQrCodes();

    function escapeHtml(value) {
        return String(value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function buildPrintableHtml(printCards) {
        var cardHtml = printCards.map(function(card) {
            return [
                '<article class="print-card">',
                '<img src="' + escapeHtml(card.imageUrl) + '" alt="' + escapeHtml('QR code for ' + card.title) + '">',
                '<div class="print-card-title">' + escapeHtml(card.title) + '</div>',
                '</article>'
            ].join('');
        }).join('');

        return [
            '<!doctype html>',
            '<html lang="en">',
            '<head>',
            '<meta charset="utf-8">',
            '<meta name="viewport" content="width=device-width, initial-scale=1">',
            '<title>Printable QR Codes</title>',
            '<style>',
            'body { margin: 16px; background: #fff; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }',
            '.print-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 8px; }',
            '.print-card { border: 1px solid #d1d5db; padding: 6px 6px 8px; text-align: center; break-inside: avoid; page-break-inside: avoid; }',
            '.print-card img { width: 130px; height: 130px; display: block; margin: 0 auto 4px; }',
            '.print-card-title { font-size: 14px; line-height: 1.2; color: #1f2937; }',
            '@media print { @page { size: Letter portrait; margin: 0.3in; } body { margin: 0; } .print-card-title { font-size: 8pt; } }',
            '</style>',
            '</head>',
            '<body>',
            '<section class="print-grid" aria-label="Printable QR code sheet">' + cardHtml + '</section>',
            '<script>',
            '(function(){',
            '  var images = Array.prototype.slice.call(document.images);',
            '  var remaining = images.length;',
            '  function done(){ setTimeout(function(){ window.print(); }, 120); }',
            '  if (!remaining) { done(); return; }',
            '  images.forEach(function(img){',
            '    function finish(){ remaining -= 1; if (remaining <= 0) { done(); } }',
            '    if (img.complete) { finish(); return; }',
            '    img.addEventListener("load", finish, { once: true });',
            '    img.addEventListener("error", finish, { once: true });',
            '  });',
            '})();',
            '<\/script>',
            '</body>',
            '</html>'
        ].join('');
    }

    document.getElementById('btn-print').addEventListener('click', function() {
        var printCards = Array.from(cards).map(function(card) {
            var img = card.querySelector('img');
            var title = card.querySelector('.qr-label strong')?.textContent?.trim() || card.dataset.shortcode;
            return {
                title: title,
                imageUrl: img ? img.src : ''
            };
        }).filter(function(card) {
            return card.imageUrl;
        });

        if (!printCards.length) {
            return;
        }

        var popup = window.open('', '_blank', 'width=1200,height=900');
        if (!popup) {
            return;
        }

        popup.document.open();
        popup.document.write(buildPrintableHtml(printCards));
        popup.document.close();
    });
})();
{% endjs %}
