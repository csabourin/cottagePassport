}

.stamp-slot { margin-bottom: 10px; }
.stamp-slot.collected { /* checked-in state */ }
.stamp-title { font-size: 1.75rem; }
.stamp-desc  { /* short description */ }
.stamp-check { /* checkmark badge overlay */ }

/*
 * ── Progress Bar ────────────────────────────────────────────
 */
.passport-progress { }
.progress-bar      { /* track */ }
.progress-fill     { /* filled portion — background matches --passport-teal */ }
.progress-text     { /* "X / Y locations" label */ }

/*
 * ── Buttons ─────────────────────────────────────────────────
 */
.passport-btn         { /* base button styles */ }
.passport-btn-primary { /* filled primary action */ }
.passport-btn-secondary { /* outline secondary action */ }

/*
 * ── Modals ──────────────────────────────────────────────────
 */
.passport-modal-content { /* modal box */ }
.passport-modal-content h2 { }
.passport-modal-close { /* × close button */ }
{% endset %}

