{% set _cssPlaceholder %}
/*
 * ── CSS Variables ───────────────────────────────────────────
 * Override these on :root to retheme the entire passport.
 */
:root {
    --passport-teal:            #2b6b8a; /* buttons, links, focus rings   */
    --passport-teal-dark:       #1e5068; /* hover / active states          */
    --passport-green:           #2d5a27; /* checked-stamp accent           */
    --passport-cream:           #f5f0e8; /* scan-strip background          */
    --passport-paper:           #f2e0c8; /* stamp-grid background          */
    --passport-beige:           #d4b896; /* borders, dividers              */
    --passport-ink:             #1e1a17; /* body text                      */
    --passport-ink-muted:       #5a4f43; /* secondary / label text         */
    --passport-radius:          4px;     /* global border-radius           */
    --passport-focus:           #2b6b8a; /* focus-visible outline colour   */
    --passport-cloth-side-color:#2f211c; /* side margin strip              */
    --passport-wood-max-width:  800px;
    --passport-wood-ratio-w:    480;     /* unitless: used in layout calc  */
    --passport-wood-ratio-h:    380;     /* unitless: used in layout calc  */
}

.passport-header-logo {
    width: 100%;
}

/*
 * ── Page Background ─────────────────────────────────────────
 */
body {
    /* Replace the gradient with a solid colour or custom image */
    /* background: #your-color; */
    /* background-image: url('/path/to/bg.jpg'); */
}

/*
 * ── Header ──────────────────────────────────────────────────
 */
.passport-header {
    /* background-color: #5c4033; */
    /* padding: 32px 28px 28px; */
}

.passport-org {
    /* Organization name above the title */
    /* font-size: 0.7rem; */
    /* letter-spacing: 0.12em; */
}

.passport-title-light {
    /* Serif light heading ("Challenge Name") */
    /* font-size: clamp(1.4rem, 4vw, 1.9rem); */
