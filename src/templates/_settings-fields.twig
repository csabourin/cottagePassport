{% import "_includes/forms" as forms %}

{# ── General ─────────────────────────────────────────────────────────────── #}
<div id="tab-general">

<h2>{{ "General"|t('stamp-passport') }}</h2>

<input type="hidden" name="pluginName" value="{{ settings.pluginName }}">

{{ forms.textField({
    first: true,
    label: "Default Route Prefix"|t('stamp-passport'),
    instructions: "Fallback URL prefix for sites that don't have their own prefix (e.g. \"passport\" → /passport)."|t('stamp-passport'),
    name: 'routePrefix',
    value: settings.routePrefix,
    required: true,
}) }}

{% for site in craft.app.sites.allSites %}
    {{ forms.textField({
        label: site.name ~ ' ' ~ "Route Prefix"|t('stamp-passport'),
        instructions: "Leave blank to use the default prefix above."|t('stamp-passport'),
        name: 'siteRoutePrefixes[' ~ site.handle ~ ']',
        value: settings.siteRoutePrefixes[site.handle] ?? '',
        placeholder: settings.routePrefix,
    }) }}
{% endfor %}

</div>{# /tab-general #}

{# ── Appearance ───────────────────────────────────────────────────────────── #}
<div id="tab-appearance" style="display:none">

<h2>{{ "Appearance"|t('stamp-passport') }}</h2>

{% set logoElements = settings.logoAssetId ? craft.assets.id(settings.logoAssetId).all() : [] %}
{{ forms.elementSelectField({
    label: "Header Logo (Primary / English)"|t('stamp-passport'),
    instructions: "Image displayed at the top of the page header. Recommended: PNG with transparent background, 50% of header width. Used for all languages unless an alternate-language logo is set."|t('stamp-passport'),
    id: 'logoAssetId',
    name: 'logoAssetId',
    elementType: 'craft\\elements\\Asset',
    criteria: { kind: 'image' },
    limit: 1,
    elements: logoElements,
    modalStorageKey: 'stamp-passport.logoAsset',
}) }}

{% set logoAltElements = settings.logoAltAssetId ? craft.assets.id(settings.logoAltAssetId).all() : [] %}
{{ forms.elementSelectField({
    label: "Header Logo (Alternate Language / French)"|t('stamp-passport'),
    instructions: "Logo shown when the site language is not the primary language (e.g. French version). Falls back to the primary logo when not set."|t('stamp-passport'),
    id: 'logoAltAssetId',
    name: 'logoAltAssetId',
    elementType: 'craft\\elements\\Asset',
    criteria: { kind: 'image' },
    limit: 1,
    elements: logoAltElements,
    modalStorageKey: 'stamp-passport.logoAltAsset',
}) }}

{% set faviconElements = settings.faviconAssetId ? craft.assets.id(settings.faviconAssetId).all() : [] %}
{{ forms.elementSelectField({
    label: "Favicon"|t('stamp-passport'),
    instructions: "Browser tab icon for the frontend page. Recommended: 32×32 or 64×64 PNG."|t('stamp-passport'),
    id: 'faviconAssetId',
    name: 'faviconAssetId',
    elementType: 'craft\\elements\\Asset',
    criteria: { kind: 'image' },
    limit: 1,
    elements: faviconElements,
    modalStorageKey: 'stamp-passport.faviconAsset',
}) }}

{% set woodElements = settings.woodPanelAssetId ? craft.assets.id(settings.woodPanelAssetId).all() : [] %}
{{ forms.elementSelectField({
    label: "Header Wood Panel"|t('stamp-passport'),
    instructions: "Background image for the page header. If not set, a CSS wood-grain texture is used as fallback."|t('stamp-passport'),
    id: 'woodPanelAssetId',
    name: 'woodPanelAssetId',
    elementType: 'craft\\elements\\Asset',
    criteria: { kind: 'image' },
    limit: 1,
    elements: woodElements,
    modalStorageKey: 'stamp-passport.woodPanelAsset',
}) }}

{% set checkedMarkerElements = settings.checkedMarkerAssetId ? craft.assets.id(settings.checkedMarkerAssetId).all() : [] %}
{{ forms.elementSelectField({
    label: "Checked Marker Image"|t('stamp-passport'),
    instructions: "Optional image shown when a location is checked. If not set, a default checkmark badge is used."|t('stamp-passport'),
    id: 'checkedMarkerAssetId',
    name: 'checkedMarkerAssetId',
    elementType: 'craft\\elements\\Asset',
    criteria: { kind: 'image' },
    limit: 1,
    elements: checkedMarkerElements,
    modalStorageKey: 'stamp-passport.checkedMarkerAsset',
}) }}

{% set bodyBackgroundElements = settings.bodyBackgroundAssetId ? craft.assets.id(settings.bodyBackgroundAssetId).all() : [] %}
{{ forms.elementSelectField({
    label: "Body Background Image"|t('stamp-passport'),
    instructions: "Optional image used as the page body background. If not set, the default pattern is used."|t('stamp-passport'),
    id: 'bodyBackgroundAssetId',
    name: 'bodyBackgroundAssetId',
    elementType: 'craft\\elements\\Asset',
    criteria: { kind: 'image' },
    limit: 1,
    elements: bodyBackgroundElements,
    modalStorageKey: 'stamp-passport.bodyBackgroundAsset',
}) }}

{{ forms.selectField({
    label: "Body Background Mode"|t('stamp-passport'),
    instructions: "How the body background image should render."|t('stamp-passport'),
    id: 'bodyBackgroundMode',
    name: 'bodyBackgroundMode',
    value: settings.bodyBackgroundMode ?? 'cover',
    options: [
        { label: "Cover"|t('stamp-passport'), value: 'cover' },
        { label: "Tiled (repeat)"|t('stamp-passport'), value: 'tiled' },
        { label: "Repeat vertically (repeat-y)"|t('stamp-passport'), value: 'repeat-y' },
        { label: "Custom size (no repeat)"|t('stamp-passport'), value: 'custom' },
    ],
}) }}

<div id="bodyBackgroundSizeField" {% if (settings.bodyBackgroundMode ?? 'cover') not in ['custom', 'repeat-y'] %}class="hidden"{% endif %}>
{{ forms.textField({
    label: "Custom Background Size"|t('stamp-passport'),
    instructions: "CSS background-size value (e.g. 800px, 50%, contain)."|t('stamp-passport'),
    id: 'bodyBackgroundSize',
    name: 'bodyBackgroundSize',
    value: settings.bodyBackgroundSize ?? '800px',
    placeholder: '800px',
}) }}
</div>

<div id="bodyBackgroundColorField" {% if (settings.bodyBackgroundMode ?? 'cover') == 'tiled' %}class="hidden"{% endif %}>
{{ forms.colorField({
    label: "Background Color"|t('stamp-passport'),
    instructions: "Fill color shown behind the background image (not applicable for tiled mode)."|t('stamp-passport'),
    id: 'bodyBackgroundColor',
    name: 'bodyBackgroundColor',
    value: settings.bodyBackgroundColor ?? '',
}) }}
</div>

{% js %}
(function () {
    var modeSelect = document.getElementById('bodyBackgroundMode');
    var sizeField  = document.getElementById('bodyBackgroundSizeField');
    var colorField = document.getElementById('bodyBackgroundColorField');
    if (!modeSelect) return;
    function updateFields() {
        var v = modeSelect.value;
        sizeField.classList.toggle('hidden',  v !== 'custom' && v !== 'repeat-y');
        colorField.classList.toggle('hidden', v === 'tiled');
    }
    modeSelect.addEventListener('change', updateFields);
}());
{% endjs %}

{% set footerBackgroundElements = settings.footerBackgroundAssetId ? craft.assets.id(settings.footerBackgroundAssetId).all() : [] %}
{{ forms.elementSelectField({
    label: "Footer Background Image"|t('stamp-passport'),
    instructions: "Decorative image anchored to the bottom of the page, layered above the page background but behind all content. The layout reserves vertical space equal to 50% of the image height so the lower half of the image is always clear. Wide landscape images work best. Leave blank for no footer image."|t('stamp-passport'),
    id: 'footerBackgroundAssetId',
    name: 'footerBackgroundAssetId',
    elementType: 'craft\\elements\\Asset',
    criteria: { kind: 'image' },
    limit: 1,
    elements: footerBackgroundElements,
    modalStorageKey: 'stamp-passport.footerBackgroundAsset',
}) }}

<h3>{{ "Brand Colors"|t('stamp-passport') }}</h3>
<p class="instructions">{{ "Override the default palette. Leave blank to use CSS defaults. Full hex values only (#rrggbb)."|t('stamp-passport') }}</p>

{{ forms.colorField({
    label: "Primary Color"|t('stamp-passport'),
    instructions: "Buttons, progress bar, links, and focus rings. Default: #2b6b8a"|t('stamp-passport'),
    id: 'primaryColor',
    name: 'primaryColor',
    value: settings.primaryColor ?? '',
}) }}

{{ forms.colorField({
    label: "Primary Color (Dark)"|t('stamp-passport'),
    instructions: "Hover and active states. Default: #1e5068"|t('stamp-passport'),
    id: 'primaryColorDark',
    name: 'primaryColorDark',
    value: settings.primaryColorDark ?? '',
}) }}

{{ forms.colorField({
    label: "Accent Color"|t('stamp-passport'),
    instructions: "Checked stamp indicator and success states. Default: #2d5a27"|t('stamp-passport'),
    id: 'accentColor',
    name: 'accentColor',
    value: settings.accentColor ?? '',
}) }}

<hr>

<h2>{{ "Social Sharing"|t('stamp-passport') }}</h2>

<p class="instructions">{{ "Open Graph meta tags control how the page appears when shared on social media. Per-site title and description are set under Display Text → \"OG / Social Share Title\" and \"OG / Social Share Description\"."|t('stamp-passport') }}</p>

{% set ogImageElements = settings.ogImageAssetId ? craft.assets.id(settings.ogImageAssetId).all() : [] %}
{{ forms.elementSelectField({
    label: "OG Share Image"|t('stamp-passport'),
    instructions: "Image used for og:image when this page is shared on social networks. Recommended: 1200×630 px."|t('stamp-passport'),
    id: 'ogImageAssetId',
    name: 'ogImageAssetId',
    elementType: 'craft\\elements\\Asset',
    criteria: { kind: 'image' },
    limit: 1,
    elements: ogImageElements,
    modalStorageKey: 'stamp-passport.ogImageAsset',
}) }}

<hr>

<h2>{{ "QR Code Appearance"|t('stamp-passport') }}</h2>

{% set qrCenterElements = settings.qrCenterImageAssetId ? craft.assets.id(settings.qrCenterImageAssetId).all() : [] %}
{{ forms.elementSelectField({
    label: "QR Center Image"|t('stamp-passport'),
    instructions: "Optional image centered in generated QR codes. Square images with transparency are recommended."|t('stamp-passport'),
    id: 'qrCenterImageAssetId',
    name: 'qrCenterImageAssetId',
    elementType: 'craft\\elements\\Asset',
    criteria: { kind: 'image' },
    limit: 1,
    elements: qrCenterElements,
    modalStorageKey: 'stamp-passport.qrCenterImageAsset',
}) }}

{{ forms.colorField({
    label: "QR Foreground Color"|t('stamp-passport'),
    instructions: "Color of the QR code dots. Default: #000000 (black). Ensure high contrast with the background color."|t('stamp-passport'),
    id: 'qrForegroundColor',
    name: 'qrForegroundColor',
    value: settings.qrForegroundColor ?? '#000000',
}) }}

{{ forms.colorField({
    label: "QR Background Color"|t('stamp-passport'),
    instructions: "Background color behind the QR code. Default: #ffffff (white)."|t('stamp-passport'),
    id: 'qrBackgroundColor',
    name: 'qrBackgroundColor',
    value: settings.qrBackgroundColor ?? '#ffffff',
}) }}

</div>{# /tab-appearance #}

{# ── Integrations ─────────────────────────────────────────────────────────── #}
<div id="tab-integrations" style="display:none">

<h2>{{ "Analytics"|t('stamp-passport') }}</h2>

{{ forms.textField({
    label: "GA4 Measurement ID"|t('stamp-passport'),
    instructions: "Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Leave blank to disable."|t('stamp-passport'),
    name: 'ga4MeasurementId',
    value: settings.ga4MeasurementId,
    placeholder: 'G-XXXXXXXXXX',
}) }}

<hr>

<h2>{{ "Freeform Integration"|t('stamp-passport') }}</h2>

{% if freeformForms is not null %}

    {{ forms.selectField({
        label: "Draw Form"|t('stamp-passport'),
        instructions: "Freeform form shown when the visitor qualifies for the draw."|t('stamp-passport'),
        id: 'freeformDrawFormHandle',
        name: 'freeformDrawFormHandle',
        value: settings.freeformDrawFormHandle ?? '',
        options: [{ label: '— None —'|t('stamp-passport'), value: '' }]|merge(freeformForms),
    }) }}

    {{ forms.selectField({
        label: "Sticker Form"|t('stamp-passport'),
        instructions: "Freeform form shown when the visitor completes every location."|t('stamp-passport'),
        id: 'freeformStickerFormHandle',
        name: 'freeformStickerFormHandle',
        value: settings.freeformStickerFormHandle ?? '',
        options: [{ label: '— None —'|t('stamp-passport'), value: '' }]|merge(freeformForms),
    }) }}

{% else %}

    {{ forms.textField({
        label: "Draw Form Handle"|t('stamp-passport'),
        instructions: "Freeform form handle for the end-of-season draw entry."|t('stamp-passport'),
        name: 'freeformDrawFormHandle',
        value: settings.freeformDrawFormHandle,
        placeholder: 'passportDraw',
    }) }}

    {{ forms.textField({
        label: "Sticker Form Handle"|t('stamp-passport'),
        instructions: "Freeform form handle for the sticker request."|t('stamp-passport'),
        name: 'freeformStickerFormHandle',
        value: settings.freeformStickerFormHandle,
        placeholder: 'passportSticker',
    }) }}

{% endif %}

</div>{# /tab-integrations #}

{# ── Advanced ─────────────────────────────────────────────────────────────── #}
<div id="tab-advanced" style="display:none">

<h2>{{ "UI Behavior"|t('stamp-passport') }}</h2>

{{ forms.lightswitchField({
    label: "Show Language Switcher"|t('stamp-passport'),
    instructions: "Display the language-switcher nav in the header. Disable for single-language sites."|t('stamp-passport'),
    name: 'showLanguageSwitcher',
    on: settings.showLanguageSwitcher,
}) }}

{{ forms.lightswitchField({
    label: "Show Organisation Name"|t('stamp-passport'),
    instructions: "Display the organisation name (orgName) below the header logo."|t('stamp-passport'),
    name: 'showOrgName',
    on: settings.showOrgName,
}) }}

{{ forms.lightswitchField({
    label: "Require Disclaimer Acknowledgement"|t('stamp-passport'),
    instructions: "Show the \"Before You Begin\" disclaimer modal on first visit. Disable for simpler flows where no privacy notice is needed."|t('stamp-passport'),
    name: 'requireDisclaimerAck',
    on: settings.requireDisclaimerAck,
}) }}

<hr>

<h2>{{ "Geofence"|t('stamp-passport') }}</h2>

{{ forms.lightswitchField({
    label: "Enable Geofence"|t('stamp-passport'),
    instructions: "When enabled, visitors must be within the configured radius of a location to check in."|t('stamp-passport'),
    name: 'enableGeofence',
    on: settings.enableGeofence,
}) }}

{{ forms.textField({
    label: "Geofence Radius (metres)"|t('stamp-passport'),
    name: 'geofenceRadius',
    value: settings.geofenceRadius,
    type: 'number',
    min: 50,
    max: 10000,
    size: 10,
}) }}

<hr>

<h2>{{ "Prizes"|t('stamp-passport') }}</h2>

{{ forms.textField({
    label: "Draw Threshold"|t('stamp-passport'),
    instructions: "Number of stamps required before the draw entry form appears."|t('stamp-passport'),
    name: 'drawThreshold',
    value: settings.drawThreshold,
    type: 'number',
    min: 1,
    size: 5,
}) }}

{{ forms.textField({
    label: "Max Stickers"|t('stamp-passport'),
    instructions: "Maximum number of sticker prizes available (0 = unlimited)."|t('stamp-passport'),
    name: 'maxStickers',
    value: settings.maxStickers,
    type: 'number',
    min: 0,
    size: 5,
}) }}

{{ forms.textField({
    label: "Contest Version"|t('stamp-passport'),
    instructions: "Bump this string when contest rules change and progress from a previous season should be treated as incompatible. Changing this value does not erase stored progress — it is included in synced payloads so the frontend can detect version mismatches."|t('stamp-passport'),
    name: 'contestVersion',
    value: settings.contestVersion,
    size: 15,
    maxlength: 20,
}) }}

<hr>

<h2>{{ "Custom CSS"|t('stamp-passport') }}</h2>

{{ forms.textareaField({
    label: "Custom CSS"|t('stamp-passport'),
    instructions: "Raw CSS injected at the end of the frontend &lt;head&gt;. Use as an escape hatch for advanced customization. Maximum 10 000 characters."|t('stamp-passport'),
    id: 'customCss',
    name: 'customCss',
    value: settings.customCss ?? '',
    rows: 10,
    class: 'code',
    maxlength: 10000,
}) }}

</div>{# /tab-advanced #}
