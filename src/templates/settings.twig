{% extends "_layouts/cp" %}

{% set title = "Settings"|t('stamp-passport') %}
{% set selectedSubnavItem = 'settings' %}

{% set crumbs = [
    { label: settings.pluginName, url: url('stamp-passport') },
] %}

{% do view.registerAssetBundle('csabourin\\stamppassport\\web\\assets\\cp\\CpAsset') %}

{% block actionButton %}
    <button type="submit" form="settings-form" class="btn submit">{{ "Save"|t('app') }}</button>
{% endblock %}

{% block content %}

<nav id="sp-settings-tabs" class="sp-tabs">
    <ul>
        <li><a href="#tab-general"      class="tab sel">{{ "General"|t('stamp-passport') }}</a></li>
        <li><a href="#tab-appearance"   class="tab">{{ "Appearance"|t('stamp-passport') }}</a></li>
        <li><a href="#tab-integrations" class="tab">{{ "Integrations"|t('stamp-passport') }}</a></li>
        <li><a href="#tab-advanced"     class="tab">{{ "Advanced"|t('stamp-passport') }}</a></li>
    </ul>
</nav>

<form method="post" accept-charset="UTF-8" id="settings-form">
    {{ csrfInput() }}
    {{ actionInput('stamp-passport/cp/save-settings') }}
    {{ redirectInput('stamp-passport/settings') }}

    {% include 'stamp-passport/_settings-fields' %}
</form>

{% endblock %}

{% js %}
(function () {
    var tabIds = ['tab-general', 'tab-appearance', 'tab-integrations', 'tab-advanced'];

    function showPanel(activeId) {
        tabIds.forEach(function (id) {
            var el = document.getElementById(id);
            if (el) el.style.display = (id === activeId) ? '' : 'none';
        });
        document.querySelectorAll('#sp-settings-tabs a').forEach(function (a) {
            a.classList.toggle('sel', a.getAttribute('href') === '#' + activeId);
        });
    }

    document.getElementById('sp-settings-tabs').addEventListener('click', function (e) {
        var a = e.target.closest('a[href^="#tab-"]');
        if (!a) return;
        e.preventDefault();
        var id = a.getAttribute('href').slice(1);
        showPanel(id);
        history.replaceState(null, '', '#' + id);
    });

    // Restore from URL hash on load, default to first tab
    var initial = (window.location.hash && tabIds.indexOf(window.location.hash.slice(1)) !== -1)
        ? window.location.hash.slice(1)
        : 'tab-general';
    showPanel(initial);
}());
{% endjs %}
