{% extends "_layouts/cp" %}

{% set title = "Settings"|t('stamp-passport') %}
{% set selectedSubnavItem = 'settings' %}

{% set crumbs = [
    { label: settings.pluginName, url: url('stamp-passport') },
] %}

{# Standard Craft CP tabs — Craft.Tabs (Garnish) manages show/hide of #tab-* panels #}
{% set tabs = {
    general:      { label: 'General'|t('stamp-passport'),      url: '#tab-general' },
    appearance:   { label: 'Appearance'|t('stamp-passport'),   url: '#tab-appearance' },
    integrations: { label: 'Integrations'|t('stamp-passport'), url: '#tab-integrations' },
    advanced:     { label: 'Advanced'|t('stamp-passport'),     url: '#tab-advanced' },
} %}

{% block actionButton %}
    <button type="submit" form="settings-form" class="btn submit">{{ "Save"|t('app') }}</button>
{% endblock %}

{% block content %}
    <form method="post" accept-charset="UTF-8" id="settings-form">
        {{ csrfInput() }}
        {{ actionInput('stamp-passport/cp/save-settings') }}
        {{ redirectInput('stamp-passport/settings') }}

        {% include 'stamp-passport/_settings-fields' %}
    </form>
{% endblock %}

{% js %}
(function () {
    var panels = document.querySelectorAll('[id^="tab-"]');

    function showPanel(hash) {
        panels.forEach(function (p) {
            p.classList.toggle('hidden', '#' + p.id !== hash);
        });
    }

    // Wire up clicks on Craft's rendered tab anchors (Craft 4 & 5 both use #tabs ul li a)
    document.querySelectorAll('#tabs a').forEach(function (a) {
        a.addEventListener('click', function (e) {
            var href = a.getAttribute('href');
            if (href && href.charAt(0) === '#') {
                e.preventDefault();
                showPanel(href);
                // Keep Craft's own selected-state styling in sync
                document.querySelectorAll('#tabs a').forEach(function (t) {
                    t.classList.toggle('sel', t === a);
                });
                history.replaceState(null, '', href);
            }
        });
    });

    // Restore tab from URL hash on page load
    var initial = window.location.hash && document.getElementById(window.location.hash.slice(1))
        ? window.location.hash
        : '#tab-general';
    showPanel(initial);

    // Sync the selected class on the matching tab link
    document.querySelectorAll('#tabs a').forEach(function (a) {
        a.classList.toggle('sel', a.getAttribute('href') === initial);
    });
}());
{% endjs %}
