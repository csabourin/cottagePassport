{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}

{% set title = "Display Text"|t('stamp-passport') %}
{% set selectedSubnavItem = 'display-text' %}

{% set crumbs = [
    { label: settings.pluginName, url: url('stamp-passport') },
] %}

{% block contextMenu %}
    {% if craft.app.isMultiSite %}
        <div>
            <button id="sp-site-btn" type="button" class="btn menubtn" data-icon="world">{{ currentSite.name }}</button>
            <div class="menu">
                <ul class="padded">
                    {% for site in allSites %}
                        <li>
                            <a href="{{ url('stamp-passport/display-text', { site: site.handle }) }}"
                               class="sp-site-link{% if site.id == currentSite.id %} sel{% endif %}">
                                {{ site.name }}
                            </a>
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    {% endif %}
{% endblock %}

{% block actionButton %}
    <button type="submit" form="display-text-form" class="btn submit">{{ "Save Display Text"|t('stamp-passport') }}</button>
{% endblock %}

{% block content %}
<form id="display-text-form" method="post" accept-charset="UTF-8">
    {{ csrfInput() }}
    {{ actionInput('stamp-passport/cp/save-display-text') }}
    {{ redirectInput('stamp-passport/display-text?site=' ~ currentSite.handle) }}

    <p class="light">{{ "Customize all display text per site. Leave fields blank to use built-in defaults for that site's language."|t('stamp-passport') }}</p>

    {% set lang = currentSite.language[:2]|lower %}
    {% set defaults = textDefaults[lang] ?? textDefaults['default'] %}

    {{ forms.textField({ label: textLabels['orgName'], name: 'uiText[' ~ currentSite.handle ~ '][orgName]', value: settings.uiText[currentSite.handle]['orgName'] ?? '', placeholder: defaults['orgName'] }) }}
    {{ forms.textField({ label: textLabels['challengeName'], name: 'uiText[' ~ currentSite.handle ~ '][challengeName]', value: settings.uiText[currentSite.handle]['challengeName'] ?? '', placeholder: defaults['challengeName'] }) }}
    {{ forms.textField({ label: textLabels['challengeTitle'], name: 'uiText[' ~ currentSite.handle ~ '][challengeTitle]', value: settings.uiText[currentSite.handle]['challengeTitle'] ?? '', placeholder: defaults['challengeTitle'] }) }}
    {{ forms.textareaField({ label: textLabels['scanInstructions'], name: 'uiText[' ~ currentSite.handle ~ '][scanInstructions]', value: settings.uiText[currentSite.handle]['scanInstructions'] ?? '', placeholder: defaults['scanInstructions'], rows: 2 }) }}
    {{ forms.textField({ label: textLabels['drawModalTitle'], name: 'uiText[' ~ currentSite.handle ~ '][drawModalTitle]', value: settings.uiText[currentSite.handle]['drawModalTitle'] ?? '', placeholder: defaults['drawModalTitle'] }) }}
    {{ forms.textareaField({ label: textLabels['drawModalBody'], name: 'uiText[' ~ currentSite.handle ~ '][drawModalBody]', value: settings.uiText[currentSite.handle]['drawModalBody'] ?? '', placeholder: defaults['drawModalBody'], rows: 2 }) }}
    {{ forms.textField({ label: textLabels['stickerModalTitle'], name: 'uiText[' ~ currentSite.handle ~ '][stickerModalTitle]', value: settings.uiText[currentSite.handle]['stickerModalTitle'] ?? '', placeholder: defaults['stickerModalTitle'] }) }}
    {{ forms.textareaField({ label: textLabels['stickerModalBody'], name: 'uiText[' ~ currentSite.handle ~ '][stickerModalBody]', value: settings.uiText[currentSite.handle]['stickerModalBody'] ?? '', placeholder: defaults['stickerModalBody'], rows: 2 }) }}
    {{ forms.textField({ label: textLabels['disclaimerTitle'], name: 'uiText[' ~ currentSite.handle ~ '][disclaimerTitle]', value: settings.uiText[currentSite.handle]['disclaimerTitle'] ?? '', placeholder: defaults['disclaimerTitle'] }) }}
    {{ forms.textareaField({ label: textLabels['disclaimerBody'], name: 'uiText[' ~ currentSite.handle ~ '][disclaimerBody]', value: settings.uiText[currentSite.handle]['disclaimerBody'] ?? '', placeholder: defaults['disclaimerBody'], rows: 2 }) }}
    {{ forms.textField({ label: textLabels['disclaimerButton'], name: 'uiText[' ~ currentSite.handle ~ '][disclaimerButton]', value: settings.uiText[currentSite.handle]['disclaimerButton'] ?? '', placeholder: defaults['disclaimerButton'] }) }}
    {{ forms.textField({ label: textLabels['alreadyCheckedIn'], name: 'uiText[' ~ currentSite.handle ~ '][alreadyCheckedIn]', value: settings.uiText[currentSite.handle]['alreadyCheckedIn'] ?? '', placeholder: defaults['alreadyCheckedIn'] }) }}
    {{ forms.textField({ label: textLabels['checkingLocation'], name: 'uiText[' ~ currentSite.handle ~ '][checkingLocation]', value: settings.uiText[currentSite.handle]['checkingLocation'] ?? '', placeholder: defaults['checkingLocation'] }) }}
    {{ forms.textField({ label: textLabels['locationError'], name: 'uiText[' ~ currentSite.handle ~ '][locationError]', value: settings.uiText[currentSite.handle]['locationError'] ?? '', placeholder: defaults['locationError'] }) }}
    {{ forms.textField({ label: textLabels['checkinFailed'], name: 'uiText[' ~ currentSite.handle ~ '][checkinFailed]', value: settings.uiText[currentSite.handle]['checkinFailed'] ?? '', placeholder: defaults['checkinFailed'] }) }}
    {{ forms.textField({ label: textLabels['checkedIn'], name: 'uiText[' ~ currentSite.handle ~ '][checkedIn]', value: settings.uiText[currentSite.handle]['checkedIn'] ?? '', placeholder: defaults['checkedIn'] }) }}
    {{ forms.textField({ label: textLabels['qrNotRecognized'], name: 'uiText[' ~ currentSite.handle ~ '][qrNotRecognized]', value: settings.uiText[currentSite.handle]['qrNotRecognized'] ?? '', placeholder: defaults['qrNotRecognized'] }) }}
    {{ forms.textField({ label: textLabels['loadError'], name: 'uiText[' ~ currentSite.handle ~ '][loadError]', value: settings.uiText[currentSite.handle]['loadError'] ?? '', placeholder: defaults['loadError'] }) }}

</form>
{% endblock %}

{% include 'stamp-passport/_cp-site-switcher-js' %}
