{% extends "_layouts/cp" %}

{% set title = "Contest Rules"|t('stamp-passport') %}
{% set selectedSubnavItem = 'contest-rules' %}

{% set crumbs = [
    { label: settings.pluginName, url: url('stamp-passport') },
] %}

{% import "_includes/forms" as forms %}

{% block content %}
    <p class="light" style="margin-bottom: 24px;">
        {{- "The Contest Rules section appears below the scan strip on the frontend only when a site has a Link Text value set. Leave all fields empty for a site to hide it."|t('stamp-passport') -}}
    </p>

    <form method="post" accept-charset="UTF-8">
        {{ csrfInput() }}
        {{ actionInput('stamp-passport/cp/save-contest-rules') }}
        {{ redirectInput('stamp-passport/contest-rules') }}

        {% for site in allSites %}
            <h2>{{ site.name }}</h2>

            {{ forms.textField({
                label: "Rules Link Text"|t('stamp-passport'),
                instructions: "The label shown on the trigger link below the scan strip. Leave empty to hide the section for this site."|t('stamp-passport'),
                name: 'contestRules[' ~ site.handle ~ '][linkText]',
                value: contestRules[site.handle].linkText ?? '',
            }) }}

            {{ forms.textareaField({
                label: "Rules Modal Content"|t('stamp-passport'),
                instructions: "HTML content displayed inside the rules modal. Supports rich text when CKEditor is installed."|t('stamp-passport'),
                id: 'stamp-rules-content-' ~ site.handle,
                name: 'contestRules[' ~ site.handle ~ '][modalContent]',
                value: contestRules[site.handle].modalContent ?? '',
                rows: 14,
            }) }}

            {{ forms.textField({
                label: "Full Rules Link Text"|t('stamp-passport'),
                instructions: 'Label for the link shown at the bottom of the modal. Defaults to "Read the full rules" if left empty.'|t('stamp-passport'),
                name: 'contestRules[' ~ site.handle ~ '][fullRulesText]',
                value: contestRules[site.handle].fullRulesText ?? '',
                placeholder: 'Read the full rules'|t('stamp-passport'),
            }) }}

            {{ forms.textField({
                label: "Full Rules URL"|t('stamp-passport'),
                instructions: "URL for the full rules link. Leave empty to hide the link."|t('stamp-passport'),
                name: 'contestRules[' ~ site.handle ~ '][fullRulesUrl]',
                value: contestRules[site.handle].fullRulesUrl ?? '',
                type: 'url',
                placeholder: 'https://',
            }) }}

            {% if not loop.last %}
                <hr style="margin: 32px 0;">
            {% endif %}
        {% endfor %}

        <div class="buttons">
            <button type="submit" class="btn submit">{{ "Save"|t('app') }}</button>
        </div>
    </form>
{% endblock %}

{# ── CKEditor 5 for each site's modal content textarea (optional dependency) ── #}
{% block foot %}
    {{ parent() }}
    {% if craft.app.plugins.getPlugin('ckeditor') %}
        {# Register the field asset bundle which includes the Craft-specific bridge #}
        {% do view.registerAssetBundle('craft\\ckeditor\\web\\assets\\field\\FieldAsset') %}
        
        {% js %}
            (function() {
                // Wait for Craft to be ready and CKEditor to load
                var initCKEditor = function() {
                    if (typeof CKEditor5 === 'undefined') {
                        setTimeout(initCKEditor, 50);
                        return;
                    }

                    {% for site in allSites %}
                        var el = document.getElementById('stamp-rules-content-{{ site.handle }}');
                        if (el && !el.dataset.ckeditorInitialized) {
                            ClassicEditor.create(el, {
                                toolbar: ['bold', 'italic', '|', 'link', 'bulletedList', 'numberedList', 'blockQuote', '|', 'undo', 'redo'],
                                // Craft specific: remove this if using vanilla ClassicEditor
                                licenseKey: '' 
                            }).then(editor => {
                                el.dataset.ckeditorInitialized = 'true';
                            });
                        }
                    {% endfor %}
                };

                initCKEditor();
            })();
        {% endjs %}
    {% endif %}
{% endblock %}
