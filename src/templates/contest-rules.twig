{% extends "_layouts/cp" %}

{% set title = "Contest Rules"|t('stamp-passport') %}
{% set selectedSubnavItem = 'contest-rules' %}

{% set crumbs = [
    { label: settings.pluginName, url: url('stamp-passport') },
] %}

{% import "_includes/forms" as forms %}

{% block contextMenu %}
    {% if craft.app.isMultiSite %}
        <div>
            <button type="button" class="btn menubtn" data-icon="world">{{ currentSite.name }}</button>
            <div class="menu">
                <ul class="padded">
                    {% for site in allSites %}
                        <li>
                            <a href="{{ url('stamp-passport/contest-rules', { site: site.handle }) }}"
                               {% if site.id == currentSite.id %}class="sel"{% endif %}>
                                {{ site.name }}
                            </a>
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    {% endif %}
{% endblock %}

{% block content %}
    <p class="light" style="margin-bottom: 24px;">
        {{ "The Contest Rules section appears below the scan strip on the frontend only when a site has a Link Text value set. Leave all fields empty for a site to hide it."|t('stamp-passport') }}
    </p>

    <form method="post" accept-charset="UTF-8">
        {{ csrfInput() }}
        {{ actionInput('stamp-passport/cp/save-contest-rules') }}
        {{ redirectInput('stamp-passport/contest-rules?site=' ~ currentSite.handle) }}

        {{ forms.textField({
            label: "Rules Link Text"|t('stamp-passport'),
            instructions: "The label shown on the trigger link below the scan strip. Leave empty to hide the section for this site."|t('stamp-passport'),
            name: 'contestRules[' ~ currentSite.handle ~ '][linkText]',
            value: contestRules[currentSite.handle].linkText ?? '',
        }) }}

        {{ forms.textareaField({
            label: "Rules Modal Content"|t('stamp-passport'),
            instructions: "HTML content displayed inside the rules modal."|t('stamp-passport'),
            name: 'contestRules[' ~ currentSite.handle ~ '][modalContent]',
            value: contestRules[currentSite.handle].modalContent ?? '',
            rows: 8,
            class: 'code',
        }) }}

        {{ forms.textField({
            label: "Full Rules Link Text"|t('stamp-passport'),
            instructions: 'Label for the link shown at the bottom of the modal. Defaults to "Read the full rules" if left empty.'|t('stamp-passport'),
            name: 'contestRules[' ~ currentSite.handle ~ '][fullRulesText]',
            value: contestRules[currentSite.handle].fullRulesText ?? '',
            placeholder: 'Read the full rules'|t('stamp-passport'),
        }) }}

        {% set fullRuleEntryElements = contestRules[currentSite.handle].fullRulesEntryId is defined and contestRules[currentSite.handle].fullRulesEntryId ? craft.entries.id(contestRules[currentSite.handle].fullRulesEntryId).all() : [] %}
        {{ forms.elementSelectField({
            label: "Full Rules Entry"|t('stamp-passport'),
            instructions: "Entry used for the full rules link. Leave empty to hide the link."|t('stamp-passport'),
            name: 'contestRules[' ~ currentSite.handle ~ '][fullRulesEntryId]',
            elementType: 'craft\\elements\\Entry',
            limit: 1,
            elements: fullRuleEntryElements,
        }) }}

        <div class="buttons">
            <button type="submit" class="btn submit">
                {{ "Save"|t('app') }}
            </button>
        </div>
    </form>
{% endblock %}
