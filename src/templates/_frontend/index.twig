{#
    Bucket list / passport frontend page.
    Override by placing _stamp-passport/index.twig in your site templates.
#}
{% extends "_stamp-passport/_layout" %}

{% set settings = craft.stampPassport.settings %}
{% set items    = craft.stampPassport.items %}
{% set t        = craft.stampPassport %}

{% set logoUrl      = settings.logoAssetId      ? craft.stampPassport.imageUrl(settings.logoAssetId)      : null %}
{% set logoAltUrl   = settings.logoAltAssetId   ? craft.stampPassport.imageUrl(settings.logoAltAssetId)   : null %}
{% set woodPanelUrl = settings.woodPanelAssetId ? craft.stampPassport.imageUrl(settings.woodPanelAssetId) : null %}
{% set checkedMarkerUrl = settings.checkedMarkerAssetId ? craft.stampPassport.imageUrl(settings.checkedMarkerAssetId) : null %}
{% set bodyBackgroundUrl = settings.bodyBackgroundAssetId ? craft.stampPassport.imageUrl(settings.bodyBackgroundAssetId) : null %}

{# Resolve which logo to show: use alt logo for non-primary language sites when available #}
{% set currentLang = currentSite.language[:2]|lower %}
{% set activeLogoUrl = (logoAltUrl and currentLang != 'en') ? logoAltUrl : logoUrl %}

{% block title %}{{ settings.pluginName }}{% endblock %}

{% block head %}
    <link rel="stylesheet" href="{{ craft.app.assetManager.getPublishedUrl('@csabourin/stamppassport/web/assets/frontend/css/passport.css', true) }}">
    {% if woodPanelUrl %}
    <style>
        .passport-header.has-wood-bg {
            --passport-wood-img: url('{{ woodPanelUrl|e }}');
        }
    </style>
    {% endif %}
    {% if bodyBackgroundUrl %}
    <style>
        body.stamp-passport {
            {% if settings.bodyBackgroundMode == 'tiled' %}
            background-image: url('{{ bodyBackgroundUrl|e }}');
            background-size: auto;
            background-repeat: repeat;
            background-position: left top;
            {% elseif settings.bodyBackgroundMode == 'repeat-y' %}
            background-image: url('{{ bodyBackgroundUrl|e }}');
            background-size: {{ settings.bodyBackgroundSize ?? '800px' }};
            background-repeat: repeat-y;
            background-position: center top;
            {% if settings.bodyBackgroundColor %}background-color: {{ settings.bodyBackgroundColor }};{% endif %}
            {% elseif settings.bodyBackgroundMode == 'custom' %}
            background-image: url('{{ bodyBackgroundUrl|e }}');
            background-size: {{ settings.bodyBackgroundSize ?? '800px' }};
            background-repeat: no-repeat;
            background-position: center top;
            {% if settings.bodyBackgroundColor %}background-color: {{ settings.bodyBackgroundColor }};{% endif %}
            {% else %}
            background-image: url('{{ bodyBackgroundUrl|e }}');
            background-size: cover;
            background-repeat: no-repeat;
            background-position: center top;
            {% if settings.bodyBackgroundColor %}background-color: {{ settings.bodyBackgroundColor }};{% endif %}
            {% endif %}
        }
    </style>
    {% endif %}
{% endblock %}

{% block content %}

{% set drawHandle    = settings.freeformDrawFormHandle %}
{% set stickerHandle = settings.freeformStickerFormHandle %}

    {# ── Header — wood panel with circular logo ── #}
    <header class="passport-header{{ woodPanelUrl ? ' has-wood-bg' : '' }}">

        {# ── Language switcher (top-right) ── #}
        {% set allSites = craft.app.sites.allSites %}
        {% if allSites|length > 1 and settings.showLanguageSwitcher %}
        <nav class="passport-lang-nav" aria-label="{{ 'Language'|t('stamp-passport') }}">
            {% for site in allSites %}
                {% if site.id != currentSite.id %}
                    {% set siteBaseUrl = (site.getBaseUrl() ?? '')|trim('/') ~ '/' %}
                    {% set _otherPrefix = settings.siteRoutePrefixes[site.handle] ?? settings.routePrefix %}
                    <a href="{{ siteBaseUrl ~ _otherPrefix }}"
                       class="passport-lang-link"
                       data-passport-lang="{{ site.language[:2] }}"
                       data-passport-href="{{ siteBaseUrl ~ _otherPrefix }}"
                       lang="{{ site.language[:2] }}"
                       hreflang="{{ site.language[:2] }}"
                       aria-label="{{ site.name }}">
                        {{ site.language[:2] }}
                    </a>
                {% endif %}
            {% endfor %}
        </nav>
        {% endif %}

        <div class="passport-header-logo">
            {% if activeLogoUrl %}
                <img src="{{ activeLogoUrl }}" alt="{{ settings.pluginName }}" class="passport-logo">
            {% else %}
                <div class="passport-logo-placeholder">🍁</div>
            {% endif %}
        </div>

        {% if settings.showOrgName %}
        <p class="passport-org">
            {{ t.text('orgName')|nl2br }}
        </p>
        {% endif %}

        <h1 class="passport-title">
            <span class="passport-title-light">{{ t.text('challengeName') }}</span>
            <span class="passport-title-bold">{{ t.text('challengeTitle') }}</span>
        </h1>
    </header>

    {# ── Instruction strip ── #}
    <div class="passport-scan-strip">
        {{ t.text('scanInstructions') }}
    </div>

    {# ── Status area for scan feedback (JS-populated, announced to AT) ── #}
    <section id="statusSection" class="passport-status hidden" role="status" aria-live="polite" aria-atomic="true"></section>

    {# ── Item list ── #}
    <section class="passport-grid" id="stampGrid">
        {% for item in items %}
            {% set content = item.contents[0] ?? null %}
            <article class="stamp-slot" data-id="{{ item.id }}">
                <button class="stamp-slot-btn"
                        type="button"
                        aria-label="{{ 'Details'|t('stamp-passport') }}: {{ content.title ?? '' }}"
                        aria-haspopup="dialog"
                        data-item-id="{{ item.id }}"
                        data-item-link-url="{{ content.linkUrl ?? '' }}"
                        data-item-link-text="{{ (content is not null and content.linkText is not empty) ? content.linkText : 'Learn more'|t('stamp-passport') }}">
                    <div class="stamp-image">
                        {% if item.imageId %}
                            {% set asset = craft.assets.id(item.imageId).one() %}
                            {% if asset %}
                                <img src="{{ asset.getUrl() }}" alt="" loading="lazy">
                            {% endif %}
                        {% endif %}
                        <div class="stamp-check hidden{{ checkedMarkerUrl ? ' has-image' : '' }}" aria-hidden="true">
                            {% if checkedMarkerUrl %}
                                <img src="{{ checkedMarkerUrl|e }}" alt="">
                            {% else %}
                                &#10003;
                            {% endif %}
                        </div>
                    </div>
                    <div class="stamp-info">
                        <h3 class="stamp-title">{{ content.title ?? '' }}</h3>
                    </div>
                    <span class="stamp-slot-chevron" aria-hidden="true">&#8250;</span>
                </button>
                {# Description HTML stored for the detail modal — not displayed inline #}
                <template id="item-desc-{{ item.id }}">{{ content.description|default('')|raw }}</template>
            </article>
        {% endfor %}
    </section>

    {# ── Progress bar ── #}
    <section class="passport-progress" aria-label="{{ 'Progress'|t('stamp-passport') }}">
        <div class="progress-bar"
             role="progressbar"
             aria-valuenow="0"
             aria-valuemin="0"
             aria-valuemax="{{ items|length }}"
             aria-describedby="progressText">
            <div class="progress-fill" id="progressFill" style="width:0%"></div>
        </div>
        <p class="progress-text" id="progressText" aria-live="polite"></p>
    </section>

    {# ── Reopen form buttons (shown by JS when dismissed but not yet submitted) ── #}
    {% if drawHandle %}
    <div id="drawReopenSection" class="passport-reopen hidden">
        <button id="drawReopenBtn" type="button" class="passport-btn passport-btn-secondary" aria-haspopup="dialog">
            {{ 'Reopen draw entry form'|t('stamp-passport') }}
        </button>
    </div>
    {% endif %}
    {% if stickerHandle %}
    <div id="stickerReopenSection" class="passport-reopen hidden">
        <button id="stickerReopenBtn" type="button" class="passport-btn passport-btn-secondary" aria-haspopup="dialog">
            {{ 'Reopen sticker request form'|t('stamp-passport') }}
        </button>
    </div>
    {% endif %}

        {# ── Contest Rules strip (optional — shown only when linkText is configured for this site) ── #}
    {% set contestRules = settings.contestRules[currentSite.handle] ?? {} %}
{% set fullRulesEntry = contestRules.fullRulesEntryId is defined and contestRules.fullRulesEntryId ? craft.entries.id(contestRules.fullRulesEntryId).one() : null %}
    {% if contestRules.linkText is defined and contestRules.linkText is not empty %}
    <div class="passport-contest-rules-strip">
        <button type="button"
                class="passport-rules-trigger"
                id="contestRulesTrigger"
                aria-haspopup="dialog"
                aria-controls="contestRulesModal"
                data-open-modal="contestRulesModal">
            {{ contestRules.linkText|e }}
        </button>
    </div>
    {% endif %}

    {# ── Item detail modal (shared, populated by JS on image click) ── #}
    <div id="itemDetailModal" class="passport-modal hidden"
         role="dialog"
         aria-modal="true"
         aria-labelledby="itemDetailModalTitle">
        <div class="passport-modal-backdrop"></div>
        <div class="passport-modal-content">
            <button class="passport-modal-close" aria-label="{{ 'Close'|t('stamp-passport') }}">&times;</button>
            <h2 id="itemDetailModalTitle" class="item-detail-title"></h2>
            <div class="item-detail-body"></div>
            <div class="item-detail-footer">
                <a class="passport-btn passport-btn-secondary item-detail-link hidden"
                   target="_blank"
                   rel="noopener noreferrer"></a>
            </div>
        </div>
    </div>

    {# ── Draw modal ── #}
    {% if drawHandle %}
        <div id="drawModal" class="passport-modal hidden" role="dialog" aria-labelledby="drawModalTitle">
            <div class="passport-modal-backdrop"></div>
            <div class="passport-modal-content">
                <button class="passport-modal-close" aria-label="{{ 'Close'|t('stamp-passport') }}">&times;</button>
                <h2 id="drawModalTitle">{{ t.text('drawModalTitle') }}</h2>
                <p>{{ t.text('drawModalBody') }}</p>
                <div id="drawFormContainer">
                    {{ craft.freeform.form(drawHandle).render() }}
                </div>
            </div>
        </div>
    {% endif %}

    {# ── Sticker modal ── #}
    {% if stickerHandle %}
        <div id="stickerModal" class="passport-modal hidden" role="dialog" aria-labelledby="stickerModalTitle">
            <div class="passport-modal-backdrop"></div>
            <div class="passport-modal-content">
                <button class="passport-modal-close" aria-label="{{ 'Close'|t('stamp-passport') }}">&times;</button>
                <h2 id="stickerModalTitle">{{ t.text('stickerModalTitle') }}</h2>
                <p>{{ t.text('stickerModalBody') }}</p>
                <div id="stickerFormContainer">
                    {{ craft.freeform.form(stickerHandle).render() }}
                </div>
            </div>
        </div>
    {% endif %}

    {# ── Contest Rules modal (optional — mirrors strip condition above) ── #}
{% set fullRulesEntry = contestRules.fullRulesEntryId is defined and contestRules.fullRulesEntryId ? craft.entries.id(contestRules.fullRulesEntryId).one() : null %}
    {% if contestRules.linkText is defined and contestRules.linkText is not empty %}
    <div id="contestRulesModal"
         class="passport-modal hidden"
         role="dialog"
         aria-modal="true"
         aria-labelledby="contestRulesModalTitle">
        <div class="passport-modal-backdrop"></div>
        <div class="passport-modal-content">
            <button class="passport-modal-close" aria-label="{{ 'Close'|t('stamp-passport') }}">&times;</button>
            <h2 id="contestRulesModalTitle">{{ contestRules.linkText|e }}</h2>
            <div class="contest-rules-body">{{ contestRules.modalContent|default('')|raw }}</div>
            {% if fullRulesEntry %}
            <div class="contest-rules-footer">
                <a href="{{ fullRulesEntry.url|e }}"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="passport-btn passport-btn-secondary">
                    {{ contestRules.fullRulesText is defined and contestRules.fullRulesText is not empty
                        ? contestRules.fullRulesText|e
                        : 'Read the full rules'|t('stamp-passport') }}
                </a>
            </div>
            {% endif %}
        </div>
    </div>
    {% endif %}

    {# ── Disclaimer modal (shown once) ── #}
    <div id="disclaimerModal" class="passport-modal hidden" role="dialog" aria-labelledby="disclaimerTitle">
        <div class="passport-modal-backdrop"></div>
        <div class="passport-modal-content">
            <h2 id="disclaimerTitle">{{ t.text('disclaimerTitle') }}</h2>
            <p>{{ t.text('disclaimerBody') }}</p>
            <button id="disclaimerAccept" class="passport-btn passport-btn-primary">
                {{ t.text('disclaimerButton') }}
            </button>
        </div>
    </div>

{% endblock %}

{% block scripts %}
    <script src="{{ craft.app.assetManager.getPublishedUrl('@csabourin/stamppassport/web/assets/frontend/js/passport.js', true) }}"></script>
{% endblock %}
