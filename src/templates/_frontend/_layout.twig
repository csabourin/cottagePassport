{#
    Default frontend layout for the Stamp Passport plugin.
    Override by placing _stamp-passport/_layout.twig in your site templates.
#}

{# Build sites list for language switch and auto-redirect #}
{% set _spSettings = craft.stampPassport.settings %}
{% set allSites = craft.app.sites.allSites %}
{% set sitesJson = [] %}
{% for site in allSites %}
    {% set siteBaseUrl = (site.getBaseUrl() ?? '')|trim('/') ~ '/' %}
    {% set _sitePrefix = _spSettings.siteRoutePrefixes[site.handle] ?? _spSettings.routePrefix %}
    {% set sitesJson = sitesJson|merge([{
        id: site.id,
        handle: site.handle,
        lang: site.language[:2],
        name: site.name,
        url: siteBaseUrl ~ _sitePrefix,
        current: (site.id == currentSite.id),
    }]) %}
{% endfor %}

<!DOCTYPE html>
<html lang="{{ currentSite.language[:2] }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">

    {# ── Favicon ── #}
    {% set faviconUrl = craft.stampPassport.imageUrl(craft.stampPassport.settings.faviconAssetId) %}
    {% if faviconUrl %}<link rel="icon" href="{{ faviconUrl|e('html_attr') }}" type="image/png">{% endif %}

    <title>{% block title %}{{ craft.stampPassport.settings.pluginName }}{% endblock %}</title>

    {# ── Open Graph / Social Sharing meta tags ── #}
    {% set ogTitle    = craft.stampPassport.text('ogTitle') %}
    {% set ogDesc     = craft.stampPassport.text('ogDescription') %}
    {% set ogImageUrl = craft.stampPassport.imageUrl(craft.stampPassport.settings.ogImageAssetId) %}
    {% if ogTitle %}<meta property="og:title" content="{{ ogTitle|e('html_attr') }}">{% endif %}
    {% if ogDesc  %}<meta property="og:description" content="{{ ogDesc|e('html_attr') }}">{% endif %}
    {% if ogImageUrl %}<meta property="og:image" content="{{ ogImageUrl|e('html_attr') }}">{% endif %}
    {% if ogTitle or ogDesc or ogImageUrl %}
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ craft.app.request.absoluteUrl|e('html_attr') }}">
    {% endif %}

    {# ── Early language redirect — runs before body to prevent flicker ── #}
    <script>
    (function(){
        var html = document.documentElement;
        var unlocked = false;
        function unlock() {
            if (unlocked) return;
            unlocked = true;
            html.style.visibility = '';
        }

        // Hold paint until language routing decision is complete.
        html.style.visibility = 'hidden';
        setTimeout(unlock, 800);

        try {
            var currentLang = '{{ currentSite.language[:2] }}'.toLowerCase();
            var sites = {{ sitesJson|json_encode|raw }};
            var params = new URL(window.location.href).searchParams;
            var LS_KEY = 'passport:langChoice';
            var DB_NAME = 'stamp-passport';
            var DB_VERSION = 2;
            var META_STORE = 'meta';
            var META_KEY = 'langChoice';

            function normalizeLang(lang) {
                return ((lang || '').substring(0, 2)).toLowerCase();
            }

            function findSiteByLang(lang) {
                for (var i = 0; i < sites.length; i++) {
                    if ((sites[i].lang || '').toLowerCase() === lang) return sites[i];
                }
                return null;
            }

            function writeLocalLang(lang) {
                try { localStorage.setItem(LS_KEY, lang); } catch (e) {}
            }

            function readLocalLang() {
                try { return normalizeLang(localStorage.getItem(LS_KEY)); } catch (e) { return ''; }
            }

            function writeIdbLang(lang) {
                return new Promise(function(resolve) {
                    try {
                        var req = indexedDB.open(DB_NAME, DB_VERSION);
                        req.onupgradeneeded = function () {
                            var d = req.result;
                            if (!d.objectStoreNames.contains(META_STORE))
                                d.createObjectStore(META_STORE, { keyPath: 'key' });
                        };
                        req.onsuccess = function () {
                            try {
                                var d = req.result;
                                var tx = d.transaction(META_STORE, 'readwrite');
                                tx.objectStore(META_STORE).put({
                                    key: META_KEY,
                                    value: lang,
                                    updatedAt: new Date().toISOString()
                                });
                                tx.oncomplete = function () { try { d.close(); } catch (e) {} resolve(); };
                                tx.onerror = function () { try { d.close(); } catch (e) {} resolve(); };
                            } catch (e) { resolve(); }
                        };
                        req.onerror = function () { resolve(); };
                        req.onblocked = function () { resolve(); };
                    } catch (e) { resolve(); }
                });
            }

            function readIdbLang() {
                return new Promise(function(resolve) {
                    try {
                        var req = indexedDB.open(DB_NAME, DB_VERSION);
                        req.onupgradeneeded = function () {
                            var d = req.result;
                            if (!d.objectStoreNames.contains(META_STORE))
                                d.createObjectStore(META_STORE, { keyPath: 'key' });
                        };
                        req.onsuccess = function () {
                            try {
                                var d = req.result;
                                var tx = d.transaction(META_STORE, 'readonly');
                                var getReq = tx.objectStore(META_STORE).get(META_KEY);
                                getReq.onsuccess = function () {
                                    var rec = getReq.result;
                                    var lang = normalizeLang(rec && rec.value);
                                    try { d.close(); } catch (e) {}
                                    resolve(lang || '');
                                };
                                getReq.onerror = function () {
                                    try { d.close(); } catch (e) {}
                                    resolve('');
                                };
                            } catch (e) { resolve(''); }
                        };
                        req.onerror = function () { resolve(''); };
                        req.onblocked = function () { resolve(''); };
                    } catch (e) { resolve(''); }
                });
            }

            function persistLangChoice(lang) {
                var normalized = normalizeLang(lang);
                if (!normalized) return Promise.resolve('');
                writeLocalLang(normalized);
                return writeIdbLang(normalized).then(function () { return normalized; });
            }

            function redirectToLang(lang) {
                var normalized = normalizeLang(lang);
                var site = findSiteByLang(normalized);
                if (!site || site.current || normalized === currentLang) return false;
                var sep = site.url.indexOf('?') === -1 ? '?' : '&';
                var targetUrl = site.url + sep + 'lang=' + encodeURIComponent(normalized);
                persistLangChoice(normalized).then(function () {
                    window.location.replace(targetUrl);
                }, function () {
                    window.location.replace(targetUrl);
                });
                return true;
            }

            function getDevicePreferredLang() {
                var browserLangs = navigator.languages || [navigator.language || navigator.userLanguage || ''];
                for (var i = 0; i < browserLangs.length; i++) {
                    var lang = normalizeLang(browserLangs[i]);
                    if (!lang) continue;
                    if (findSiteByLang(lang)) return lang;
                }
                return '';
            }

            // If user arrived via explicit language switch or cross-domain link, record their choice.
            if (params.has('lang') || params.has('cid')) {
                persistLangChoice(currentLang).then(unlock, unlock);
                return;
            }

            // Prefer an already saved choice first.
            var localChoice = readLocalLang();
            if (localChoice) {
                if (redirectToLang(localChoice)) return;
                persistLangChoice(localChoice).then(unlock, unlock);
                return;
            }

            // No local value: check IndexedDB, then fallback to device language.
            readIdbLang().then(function (savedChoice) {
                if (savedChoice) {
                    if (redirectToLang(savedChoice)) return;
                    persistLangChoice(savedChoice).then(unlock, unlock);
                    return;
                }
                var preferred = getDevicePreferredLang();
                if (preferred && redirectToLang(preferred)) return;
                unlock();
            }, function () {
                var preferred = getDevicePreferredLang();
                if (preferred && redirectToLang(preferred)) return;
                unlock();
            });
        } catch(e) { unlock(); }
    })();
    </script>

    {% block head %}{% endblock %}

    {# ── Brand color CSS variable overrides — injected after stylesheet, so vars win ── #}
    {% set _s = craft.stampPassport.settings %}

    {# ── Footer background image — decorative, document-anchored ── #}
    {% set _footerBgAsset = _s.footerBackgroundAssetId ? craft.assets.id(_s.footerBackgroundAssetId).one() : null %}
    {% if _footerBgAsset and _footerBgAsset.width and _footerBgAsset.height %}
    {% set _footerBgPaddingVw = (50 * _footerBgAsset.height / _footerBgAsset.width)|round(3) %}
    {# Guard against volumes that embed an absolute CDN URL inside a local path, producing
       strings like /cpresources/hash/https://cdn.example/... or https://site/https://cdn/...
       Split on :// and reconstruct from the last scheme token when :// appears in non-scheme
       position (parts[0] is not http/https) or more than one :// is present.
       Do NOT use |e('html_attr') inside <style> — it encodes : and / via &#x3A; etc., which
       the CSS parser treats as literals, breaking the URL entirely. #}
    {% set _footerBgUrl = _footerBgAsset.url %}
    {% set _footerBgUrlParts = _footerBgUrl|split('://') %}
    {% if _footerBgUrlParts|length > 2 %}
        {# e.g. https://site.example/cpresources/hash/https://cdn.example/path #}
        {% set _footerBgUrl = (_footerBgUrlParts[1]|split('/')|last) ~ '://' ~ _footerBgUrlParts[2] %}
    {% elseif _footerBgUrlParts|length == 2 and _footerBgUrlParts[0] not in ['http', 'https'] %}
        {# e.g. /cpresources/hash/https://cdn.example/path #}
        {% set _footerBgUrl = (_footerBgUrlParts[0]|split('/')|last) ~ '://' ~ _footerBgUrlParts[1] %}
    {% endif %}
    <style>
    body.stamp-passport {
        --passport-footer-bg-img: url("{{ _footerBgUrl|replace({'"': '%22'}) }}");
        --passport-footer-bg-ar-w: {{ _footerBgAsset.width }};
        --passport-footer-bg-ar-h: {{ _footerBgAsset.height }};
    }
    .passport-main { padding-bottom: {{ _footerBgPaddingVw }}vw; }
    </style>
    {% endif %}

    {% if _s.primaryColor or _s.primaryColorDark or _s.accentColor %}
    <style>
    :root {
        {% if _s.primaryColor %}--passport-teal: {{ _s.primaryColor|e }};--passport-focus: {{ _s.primaryColor|e }};{% endif %}
        {% if _s.primaryColorDark %}--passport-teal-dark: {{ _s.primaryColorDark|e }};{% endif %}
        {% if _s.accentColor %}--passport-green: {{ _s.accentColor|e }};{% endif %}
    }
    </style>
    {% endif %}

    {# ── Custom CSS escape hatch — always last, wins specificity ── #}
    {% if _s.customCssEnabled and _s.customCss %}
    <style id="stamp-passport-custom-css">{{ _s.customCss|raw }}</style>
    {% endif %}

    {# GA4 — only if configured #}
    {% set ga4Id = craft.stampPassport.settings.ga4MeasurementId %}
    {% if ga4Id %}
        <script async src="https://www.googletagmanager.com/gtag/js?id={{ ga4Id }}"></script>
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', '{{ ga4Id }}');
        </script>
    {% endif %}
</head>
<body class="stamp-passport{% if _footerBgAsset and _footerBgAsset.width and _footerBgAsset.height %} has-footer-bg{% endif %}">
    {% block body %}
        {% if _footerBgAsset and _footerBgAsset.width and _footerBgAsset.height %}
        <div class="passport-footer-bg" aria-hidden="true" role="presentation"></div>
        {% endif %}
        <main class="passport-main">
            {% block content %}{% endblock %}
        </main>
    {% endblock %}

    {# Passport configuration injected for JS #}
    {% set t = craft.stampPassport %}
    <script>
        window.__PASSPORT_CONFIG__ = {
            locationsUrl: '{{ craft.stampPassport.locationsActionUrl()|e("js") }}',
            collectUrl:   '{{ craft.stampPassport.collectActionUrl()|e("js") }}',
            resolveUrl:   '{{ craft.stampPassport.resolveActionUrl()|e("js") }}',
            drawThreshold: {{ craft.stampPassport.settings.drawThreshold }},
            maxStickers:   {{ craft.stampPassport.settings.maxStickers }},
            enableGeofence: {{ craft.stampPassport.settings.enableGeofence ? 'true' : 'false' }},
            contestProgressUrl: '{{ craft.stampPassport.contestProgressUrl()|e("js") }}',
            contestVersion: '{{ craft.stampPassport.settings.contestVersion|e("js") }}',
            showLanguageSwitcher: {{ craft.stampPassport.settings.showLanguageSwitcher ? 'true' : 'false' }},
            requireDisclaimerAck: {{ craft.stampPassport.settings.requireDisclaimerAck ? 'true' : 'false' }},
            lang: '{{ currentSite.language[:2] }}',
            sites: {{ sitesJson|json_encode|raw }},
            text: {
                alreadyCheckedIn: '{{ t.text("alreadyCheckedIn")|e("js") }}',
                checkingLocation: '{{ t.text("checkingLocation")|e("js") }}',
                locationError:    '{{ t.text("locationError")|e("js") }}',
                checkinFailed:    '{{ t.text("checkinFailed")|e("js") }}',
                checkedIn:        '{{ t.text("checkedIn")|e("js") }}',
                qrNotRecognized:  '{{ t.text("qrNotRecognized")|e("js") }}',
                loadError:        '{{ t.text("loadError")|e("js") }}',
                learnMore:        '{{ "Learn more"|t("stamp-passport")|e("js") }}',
                errorPrefix:      '{{ "Error: "|t("stamp-passport")|e("js") }}',
            },
        };
    </script>

    {% block scripts %}{% endblock %}
</body>
</html>
